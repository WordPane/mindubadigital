---
import Base from '../layouts/Base.astro';
import { whatsappLink, waMessages } from '../data/site';
---

<Base
  title="Página não encontrada | Minduba Digital"
  description="A página que você procura não existe ou foi movida. Fale com a Minduba Digital no WhatsApp ou volte para a página inicial."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow" />
  </Fragment>

  <main class="not-found">
    <p class="nf-code text-gradient">404</p>
    <h1>Essa página saiu do ar — mas a gente resolve.</h1>
    <p>
      O endereço que você tentou acessar não existe ou foi movido. Volte para a
      página inicial ou chame a gente direto no WhatsApp.
    </p>
    <div class="nf-actions">
      <a class="btn btn-primary" href="/">Voltar para o início</a>
      <a
        class="btn btn-ghost"
        href={whatsappLink(waMessages.default)}
        target="_blank"
        rel="noopener noreferrer"
      >
        Chamar no WhatsApp
      </a>
    </div>
  </main>
</Base>

<style>
  .not-found {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.25rem;
  }

  .nf-code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 9rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    max-width: 34rem;
    margin-bottom: 1rem;
  }

  main > p:not(.nf-code) {
    color: var(--c-muted);
    max-width: 30rem;
    margin-bottom: 2.25rem;
  }

  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
</style>
