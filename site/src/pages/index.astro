---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import Services from '../components/Services.astro';
import OtherServices from '../components/OtherServices.astro';
import WhyMinduba from '../components/WhyMinduba.astro';
import Process from '../components/Process.astro';
import Cases from '../components/Cases.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import CtaFinal from '../components/CtaFinal.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<Base
  title="Minduba Digital | Tráfego Pago e Criação de Sites que Geram Resultado"
  description="Agência de marketing digital especialista em tráfego pago e criação de sites de alta conversão. Estratégia, dados e foco em resultado real. Peça um orçamento grátis no WhatsApp."
>
  <Header />
  <main id="topo">
    <Hero />
    <LogoMarquee />
    <Services />
    <OtherServices />
    <WhyMinduba />
    <Process />
    <Cases />
    <Testimonials />
    <Faq />
    <CtaFinal />
  </main>
  <Footer />
  <WhatsAppFloat />
</Base>
