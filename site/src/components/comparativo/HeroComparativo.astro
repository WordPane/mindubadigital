---
import { comparativo } from '../../data/comparativo';
---

<section class="hero-cmp section">
  <div class="container">
    <div class="section-head center">
      <p class="eyebrow">Estudo de caso real</p>
      <h1 class="section-title">
        A diferença entre um site no ar<br />e um site <span class="text-gradient">que vende</span>
      </h1>
      <p class="section-sub">
        Refizemos o nosso próprio site com a mesma solução que entregamos aos clientes.
        Mesma marca, mesmo segmento — e um resultado completamente diferente. Compare você mesmo.
      </p>
      <p class="scroll-hint">Passe o mouse sobre cada site para rolar a página completa</p>
    </div>

    <div class="versus">
      <div class="shot-head head-old">
        <span class="shot-tag">Antes · {comparativo.antigo.tecnologia}</span>
        <span class="shot-url">{comparativo.antigo.url}</span>
      </div>
      <div class="shot-head head-new">
        <span class="shot-tag tag-new">Depois · {comparativo.novo.tecnologia}</span>
        <span class="shot-url">{comparativo.novo.url}</span>
      </div>

      <div class="shot-frame frame-old" style="--scroll-time: 6s">
        <img
          src="/comparativo/site-antigo.jpg"
          alt="Página completa do site antigo da Minduba Digital, feito em WordPress"
          width="1100"
          height="3789"
          decoding="async"
        />
      </div>
      <div class="shot-frame frame-new" style="--scroll-time: 9s">
        <img
          src="/comparativo/site-novo.jpg"
          alt="Página completa do novo site da Minduba Digital"
          width="1100"
          height="5831"
          decoding="async"
        />
      </div>

      <span class="vs-badge" aria-hidden="true">VS</span>
    </div>
  </div>
</section>

<style>
  .hero-cmp {
    padding-top: clamp(2.5rem, 6vw, 4rem);
  }

  .scroll-hint {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: var(--c-muted);
  }

  .versus {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      'head-old head-new'
      'frame-old frame-new';
    align-items: start;
    column-gap: clamp(1rem, 3vw, 2rem);
  }

  .head-old {
    grid-area: head-old;
  }

  .head-new {
    grid-area: head-new;
  }

  .frame-old {
    grid-area: frame-old;
  }

  .frame-new {
    grid-area: frame-new;
  }

  .shot-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .shot-tag {
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-muted);
    background: var(--c-card);
    border: 1px solid var(--c-border);
    white-space: nowrap;
  }

  .tag-new {
    color: #fff;
    background: var(--gradient);
    border-color: transparent;
  }

  .shot-url {
    font-size: 0.8125rem;
    color: var(--c-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .shot-frame {
    overflow: hidden;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    box-shadow: 0 32px 64px -32px rgba(0, 0, 0, 0.8);
  }

  /* Rolagem do print completo no hover */
  .shot-frame img {
    width: 100%;
    aspect-ratio: 8 / 5;
    object-fit: cover;
    object-position: top;
    transition: object-position var(--scroll-time, 8s) ease;
  }

  .shot-frame:hover img {
    object-position: bottom;
  }

  /* Selo centralizado na linha das imagens (linha 2 do grid) */
  .vs-badge {
    grid-row: 2;
    grid-column: 1 / -1;
    place-self: center;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 3.5rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--gradient);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.04em;
    box-shadow: 0 12px 32px -8px rgba(255, 72, 14, 0.65);
  }

  @media (max-width: 48rem) {
    .versus {
      grid-template-columns: 1fr;
      grid-template-areas:
        'head-old'
        'frame-old'
        'head-new'
        'frame-new';
    }

    .vs-badge {
      position: absolute;
      left: 50%;
      top: 50%;
      translate: -50% -50%;
    }
  }
</style>
