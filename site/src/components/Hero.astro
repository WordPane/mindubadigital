---
import { whatsappLink, waMessages } from '../data/site';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-glow hero-glow-1" aria-hidden="true"></div>
  <div class="hero-glow hero-glow-2" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="container hero-inner">
    <p class="eyebrow">Agência de Marketing Digital</p>

    <h1 id="hero-title">
      <span class="h1-line">Sites que <span class="text-gradient">vendem</span>.</span>
      <span class="h1-line">Tráfego que <span class="text-gradient">converte</span>.</span>
    </h1>

    <p class="hero-sub">
      Chega de investir no escuro. A Minduba cria sites que vendem e campanhas
      de tráfego que dão retorno — com estratégia, dados e acompanhamento de
      perto, <strong>do primeiro clique à venda</strong>.
    </p>

    <div class="hero-actions">
      <a
        class="btn btn-primary btn-lg"
        href={whatsappLink(waMessages.orcamento)}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.497.1-.198.05-.371-.025-.52-.074-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/>
        </svg>
        Quero um orçamento grátis
      </a>
      <a class="btn btn-ghost btn-lg" href="#servicos">Conhecer as soluções</a>
    </div>

    <ul class="hero-proof" aria-label="Prova social">
      <li>
        <span class="stars" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        </span>
        <span><strong>5,0 no Google</strong> · 22 avaliações</span>
      </li>
      <li><strong>+48 empresas</strong> atendidas</li>
      <li><strong>Sem pacotes prontos</strong>: estratégia sob medida</li>
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding-block: 9rem 5rem;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: radial-gradient(ellipse 90% 65% at 50% 0%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 65% at 50% 0%, black 30%, transparent 75%);
  }

  .hero-glow {
    position: absolute;
    z-index: -3;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.5;
  }

  .hero-glow-1 {
    width: 42rem;
    height: 42rem;
    top: -18rem;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(255, 107, 0, 0.35), rgba(255, 27, 24, 0.12) 60%, transparent 75%);
  }

  .hero-glow-2 {
    width: 26rem;
    height: 26rem;
    bottom: -12rem;
    right: -8rem;
    background: radial-gradient(circle, rgba(255, 72, 14, 0.22), transparent 70%);
  }

  .hero-inner {
    max-width: 56rem;
    text-align: center;
  }

  .hero-inner .eyebrow {
    justify-content: center;
  }

  h1 {
    font-size: clamp(2.35rem, 7vw, 4.75rem);
    margin-bottom: 1.5rem;
  }

  .h1-line {
    display: block;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: var(--c-muted);
    max-width: 42rem;
    margin: 0 auto 2.5rem;
  }

  .hero-sub strong {
    color: var(--c-text);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .btn-lg {
    padding: 1.1rem 2.1rem;
    font-size: 1.0625rem;
  }

  .hero-proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.75rem 2.25rem;
    color: var(--c-muted);
    font-size: 0.9375rem;
  }

  .hero-proof li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hero-proof strong {
    color: var(--c-text);
    font-weight: 600;
  }

  .stars {
    display: inline-flex;
    gap: 2px;
    color: #ffc531;
  }

  @media (max-width: 40rem) {
    .hero {
      padding-block: 7.5rem 4rem;
    }

    .hero-actions .btn {
      width: 100%;
    }
  }
</style>
