---
import { whatsappLink, waMessages } from '../data/site';

const steps = [
  {
    title: 'Conhecendo o seu negócio',
    description:
      'Entendemos sua realidade, metas e diferenciais. Com isso, traçamos uma rota estratégica totalmente personalizada.',
  },
  {
    title: 'Análise da concorrência',
    description:
      'Mergulhamos no seu mercado para identificar oportunidades, ameaças e brechas que seus concorrentes não enxergam.',
  },
  {
    title: 'Configuração inicial',
    description:
      'Organizamos e otimizamos contas de anúncio, pixel, eventos e conversões para garantir uma base sólida.',
  },
  {
    title: 'Implementação e acompanhamento',
    description:
      'Colocamos tudo no ar com foco em testes, performance e clareza de métricas desde o primeiro clique.',
  },
  {
    title: 'Dados em resultados',
    description:
      'Avaliamos, cruzamos e interpretamos dados para entender o que realmente gera retorno para o seu negócio.',
  },
  {
    title: 'Otimização contínua',
    description:
      'Nada de campanhas abandonadas. Análise e ajustes constantes para escalar os melhores resultados.',
  },
];
---

<section class="section process" id="processo" aria-labelledby="process-title">
  <div class="container">
    <div class="section-head center reveal">
      <p class="eyebrow">Método comprovado</p>
      <h2 class="section-title" id="process-title">
        Um processo completo para o <span class="text-gradient">seu sucesso</span>
      </h2>
      <p class="section-sub">
        Cada cliente é único. Por isso o processo é montado para a sua
        realidade — e não o contrário.
      </p>
    </div>

    <ol class="steps">
      {steps.map((step, index) => (
        <li class="step reveal">
          <span class="step-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </li>
      ))}
    </ol>

    <div class="process-cta reveal">
      <a class="btn btn-primary btn-lg" href={whatsappLink(waMessages.orcamento)} target="_blank" rel="noopener noreferrer">
        Quero começar agora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--c-bg-soft);
    border-block: 1px solid var(--c-border);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    counter-reset: step;
  }

  .step {
    position: relative;
    padding: 1.75rem;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .step:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 107, 0, 0.4);
  }

  .step-number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1rem;
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0.9;
  }

  .step h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .step p {
    color: var(--c-muted);
    font-size: 0.9375rem;
  }

  .process-cta {
    display: flex;
    justify-content: center;
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }

  .btn-lg {
    padding: 1.1rem 2.1rem;
    font-size: 1.0625rem;
  }

  @media (max-width: 56rem) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 34rem) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
